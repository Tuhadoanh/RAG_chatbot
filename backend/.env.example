# ── Google AI ─────────────────────────────────────────────────────────────────
# Lấy tại: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=rag_user
MYSQL_PASSWORD=strongpassword
MYSQL_DATABASE=rag_chatbot

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=rag_chatbot

# ── RAG / Retriever tuning ────────────────────────────────────────────────────
RETRIEVER_SCORE_THRESHOLD=0.5
RETRIEVER_K=5
BM25_WEIGHT=0.3
FAISS_WEIGHT=0.7
EMBEDDING_BATCH_SIZE=1400

# ── Paths (relative to backend/) ──────────────────────────────────────────────
DB_FAISS_PATH=faiss_db
BM25_INDEX_PATH=bm25_index/bm25.pkl
NEW_SOURCES_PATH=./New_Sources
